# LLM draft generation settings
LLM_PROVIDER=mock
# LLM_PROVIDER=openai_compatible 인 경우 아래 필수
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# auto|responses|chat (gpt_oss_example 방식이면 responses 권장)
LLM_API_STYLE=auto


# Oracle DB connection (optional: overrides report_map.json db fields)
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=
ORACLE_USER=
ORACLE_PW=
# ORACLE_DSN=HOST:PORT/SERVICE

# GPT-OSS gateway settings (LLM_PROVIDER=gpt_oss)
GPT_OSS_API_URL=http://apigw.samsungds.net:8000/gpt-oss/1/gpt-oss-120b/v1/chat/completions
GPT_OSS_CREDENTIAL_KEY=
GPT_OSS_USER_ID=
GPT_OSS_USER_TYPE=AD_ID
GPT_OSS_SEND_SYSTEM_NAME=
GPT_OSS_MODEL=openai/gpt-oss-120b
