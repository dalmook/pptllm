{
  "report_name": "샘플 보고서",
  "output_filename_prefix": "sample_report",
  "db": {
    "user": "USER",
    "password": "PASSWORD",
    "dsn": "HOST:1521/SERVICE"
  },
  "bindings": [
    {
      "shape_name": "txt_summary",
      "bind_type": "text",
      "enabled": true
    },
    {
      "shape_name": "tbl_main",
      "bind_type": "tbl",
      "sql_key": "main_table",
      "columns": ["COL_A", "COL_B"],
      "header_row": 1,
      "clear_existing": true,
      "enabled": true
    },
    {
      "shape_name": "tbl_repeat",
      "bind_type": "tblr",
      "sql_key": "daily_rows",
      "template_row": 4,
      "enabled": true,
      "keep_template_row_if_empty": true,
      "clear_placeholders_if_empty": true
    },
    {
      "shape_name": "tbl_anchor",
      "bind_type": "tblx",
      "sql_key": "pmix_qtr",
      "header_row": 1,
      "key_fields": ["FAM1", "USERFAM1", "DR"],
      "strict_match": false,
      "enabled": true
    },
    {
      "shape_name": "cht_trend",
      "bind_type": "cht",
      "sql_key": "sales_trend",
      "category_field": "MONTH",
      "series_fields": ["QTY", "AMT"],
      "enabled": true
    }
  ]
}
