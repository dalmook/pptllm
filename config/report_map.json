    {
      "shape_name": "tbl_anchor",
      "bind_type": "tblx",
      "sql_key": "anchor_metrics",
      "key_fields": ["FAM1", "USERFAM1", "DR"],
      "enabled": false
    },
    {
      "shape_name": "cht_sales",
      "bind_type": "cht",
      "sql_key": "sales_chart",
      "category_field": "MONTH",
      "series_fields": ["ACTUAL", "TARGET"],
      "enabled": false
    }
  ]
